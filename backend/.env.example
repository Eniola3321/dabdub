# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
FRONTEND_URL=http://localhost:3001

# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=cheese_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Throttler
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Flutterwave
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_WEBHOOK_SECRET=your-flutterwave-webhook-secret
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com

# SMS — Termii
TERMII_API_KEY=your_termii_api_key_here
TERMII_SENDER_ID=Cheese

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Email (Nodemailer — SMTP or SendGrid)
# For SendGrid: set EMAIL_SMTP_HOST=smtp.sendgrid.net, EMAIL_SMTP_USER=apikey, EMAIL_SMTP_PASS=<your_sendgrid_api_key>
# For plain SMTP: set host/port/user/pass for your SMTP server
EMAIL_PROVIDER=smtp
EMAIL_SMTP_HOST=smtp.sendgrid.net
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=apikey
EMAIL_SMTP_PASS=your_sendgrid_api_key_or_smtp_password
EMAIL_FROM=noreply@cheesepay.xyz
EMAIL_FROM_NAME=CheesePay
